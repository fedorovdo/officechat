{$OFFICECHAT_HOSTNAME:officechat.example.local} {
	tls internal
	encode gzip zstd

	request_body {
		max_size 60MB
	}

	log {
		output stdout
		format console
	}

	@frontend_health path /api/health /api/health/*
	handle @frontend_health {
		reverse_proxy frontend:3000
	}

	@backend path /api /api/* /docs /docs/* /redoc /redoc/* /openapi.json /ready /health /healthz
	handle @backend {
		reverse_proxy backend:8000
	}

	handle {
		reverse_proxy frontend:3000
	}
}
