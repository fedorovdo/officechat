{
  "name": "OfficeChat",
  "short_name": "OC",
  "description": "A self-hosted corporate messenger for chats, announcements, notifications and events.",
  "start_url": "/ru/app",
  "display": "standalone",
  "background_color": "#f7f8fb",
  "theme_color": "#1f2d29",
