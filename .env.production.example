# OfficeChat production configuration example.
# Copy to a secure location and replace every placeholder secret before use.

APP_NAME=OfficeChat
APP_VERSION=0.1.0-rc1
ENVIRONMENT=production

# Required: persistent strong secret, 32+ random characters. Never commit the real value.
APP_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=1440

POSTGRES_DB=officechat
POSTGRES_USER=officechat
POSTGRES_PASSWORD=replace-with-postgres-password
DATABASE_URL=postgresql://officechat:replace-with-postgres-password@postgres:5432/officechat

PUBLIC_FRONTEND_URL=https://chat.example.com
PUBLIC_BACKEND_URL=https://chat.example.com
BACKEND_CORS_ORIGINS=https://chat.example.com

VALKEY_DB=0
PRESENCE_CONNECTION_TTL_SECONDS=90
PRESENCE_HEARTBEAT_SECONDS=25
PRESENCE_OFFLINE_GRACE_SECONDS=15
TYPING_TTL_SECONDS=5

AUDIT_RETENTION_DAYS=365
AUDIT_MAX_EXPORT_ROWS=10000
MESSAGE_MAX_LENGTH=4000
PINNED_MESSAGES_MAX_PER_CHAT=20
BROADCAST_TITLE_MAX_LENGTH=160
BROADCAST_BODY_MAX_LENGTH=10000
BROADCAST_MAX_RECIPIENTS=10000
BROADCAST_MAX_PER_HOUR=10
BROADCAST_PREVIEW_TTL_SECONDS=300
BROADCAST_RETENTION_DAYS=365
NOTIFICATION_RETENTION_DAYS=90
NOTIFICATION_MAX_PER_USER=5000
CALENDAR_TITLE_MAX_LENGTH=200
CALENDAR_DESCRIPTION_MAX_LENGTH=10000
CALENDAR_LOCATION_MAX_LENGTH=500
CALENDAR_MAX_RECIPIENTS=10000
CALENDAR_DEFAULT_TIMEZONE=Europe/Moscow
CALENDAR_MAX_REMINDERS=5
CALENDAR_MAX_DURATION_DAYS=30
CALENDAR_REMINDER_POLL_SECONDS=30
CALENDAR_REMINDER_BATCH_SIZE=100

ATTACHMENT_MAX_UPLOAD_SIZE_MB=25
ATTACHMENT_MAX_FILES_PER_MESSAGE=10
ATTACHMENT_MAX_TOTAL_SIZE_MB=50
ALLOWED_UPLOAD_EXTENSIONS=txt,log,csv,md,json,xml,yaml,yml,ini,conf,pdf,doc,docx,xls,xlsx,png,jpg,jpeg,webp,zip
AVATAR_MAX_UPLOAD_SIZE_MB=5
ALLOWED_AVATAR_EXTENSIONS=png,jpg,jpeg,webp

NEXT_PUBLIC_DEFAULT_LOCALE=ru
FRONTEND_HOST_PORT=3100
