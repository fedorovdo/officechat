# OfficeChat local development configuration

APP_NAME=OfficeChat
APP_VERSION=0.1.0
ENVIRONMENT=development
SELF_REGISTRATION_ENABLED=false
# Development only. Set a long, persistent secret in production; changing it invalidates all active sessions.
APP_SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUDIT_RETENTION_DAYS=365
AUDIT_MAX_EXPORT_ROWS=10000
MESSAGE_MAX_LENGTH=4000
ATTACHMENT_MAX_UPLOAD_SIZE_MB=25
ATTACHMENT_MAX_FILES_PER_MESSAGE=10
ATTACHMENT_MAX_TOTAL_SIZE_MB=50
ALLOWED_UPLOAD_EXTENSIONS=txt,log,csv,md,json,xml,yaml,yml,ini,conf,pdf,doc,docx,xls,xlsx,png,jpg,jpeg,webp,zip
AVATAR_MAX_UPLOAD_SIZE_MB=5
ALLOWED_AVATAR_EXTENSIONS=png,jpg,jpeg,webp

# Development bootstrap only. Change these before any shared or production deployment.
BOOTSTRAP_SUPERADMIN_USERNAME=admin
BOOTSTRAP_SUPERADMIN_PASSWORD=admin12345
BOOTSTRAP_SUPERADMIN_DISPLAY_NAME=OfficeChat Admin

POSTGRES_DB=officechat
POSTGRES_USER=officechat
POSTGRES_PASSWORD=officechat_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=1800

VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_DB=0
PRESENCE_CONNECTION_TTL_SECONDS=90
PRESENCE_HEARTBEAT_SECONDS=25
PRESENCE_OFFLINE_GRACE_SECONDS=15
TYPING_TTL_SECONDS=5

BACKEND_CORS_ORIGINS=http://localhost:3100
UPLOADS_DIR=/data/uploads

NEXT_PUBLIC_DEFAULT_LOCALE=ru
NEXT_PUBLIC_BACKEND_URL=http://localhost:8100
