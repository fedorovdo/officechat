# OfficeChat local development configuration

APP_NAME=OfficeChat
APP_VERSION=0.1.0
ENVIRONMENT=development
SELF_REGISTRATION_ENABLED=false

POSTGRES_DB=officechat
POSTGRES_USER=officechat
POSTGRES_PASSWORD=officechat_dev_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_DB=0

BACKEND_CORS_ORIGINS=http://localhost:3100
UPLOADS_DIR=/data/uploads

NEXT_PUBLIC_DEFAULT_LOCALE=ru
NEXT_PUBLIC_BACKEND_URL=http://localhost:8100
